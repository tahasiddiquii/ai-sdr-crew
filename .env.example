# Offline default: no keys, deterministic crew.
SDR_PROVIDER=mock

# Real CrewAI crew (needs the [crew] extra + a key):
# SDR_PROVIDER=openai
# OPENAI_API_KEY=sk-...

SDR_MODEL=gpt-5.2

# Ideal Customer Profile.
SDR_ICP_INDUSTRIES=saas,fintech,e-commerce,healthtech,devtools
SDR_ICP_REGIONS=north america,europe
SDR_ICP_MIN_EMPLOYEES=50
SDR_ICP_MAX_EMPLOYEES=5000

# Tier thresholds on the 0-100 fit score.
SDR_TIER_A=80
SDR_TIER_B=60
SDR_TIER_C=40

SDR_WEB_ORIGIN=http://localhost:3000

# Optional Langfuse v4 (OpenTelemetry-native) tracing.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
